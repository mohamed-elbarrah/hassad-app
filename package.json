{
  "name": "hassad",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "watch:shared": "npm --prefix packages/shared run watch",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "latest",
    "prettier": "^3.x"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.x",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
