# apps/web/.env.example

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# Frontend App URL
APP_URL=http://localhost:3000

# JWT Secret — must match apps/api/.env JWT_SECRET (used by Edge middleware)
JWT_SECRET="change-me-to-match-api"

# AI Configuration (Phase 6C)
GEMINI_API_KEY=""
