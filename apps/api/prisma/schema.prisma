// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  PM
  SALES
  EMPLOYEE
  MARKETING
  ACCOUNTANT
  CLIENT
}

enum ClientStatus {
  LEAD
  ACTIVE
  STOPPED
}

/// The 9 CRM sales pipeline stages, in order of progression.
enum PipelineStage {
  NEW_LEAD
  INTRO_MESSAGE
  CONTACT_ATTEMPT
  MEETING_SCHEDULED
  MEETING_HELD
  PROPOSAL
  FOLLOW_UP
  APPROVAL
  CONTRACT_SIGNED
}

enum ContactOutcome {
  NO_RESPONSE
  RESPONDED
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskDepartment {
  DESIGN
  MARKETING
  DEVELOPMENT
  CONTENT
  MANAGEMENT
}

enum BusinessType {
  RESTAURANT
  CLINIC
  STORE
  SERVICE
}

enum ClientSource {
  AD
  REFERRAL
  WEBSITE
  WHATSAPP
  PLATFORM
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id            String          @id @default(cuid())
  name          String
  email         String          @unique
  passwordHash  String
  role          UserRole        @default(EMPLOYEE)
  department    TaskDepartment?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  assignedClients  Client[]       @relation("AssignedTo")
  managedProjects  Project[]      @relation("ProjectManager")
  tasks            Task[]         @relation("AssignedTask")
  uploadedFiles    TaskFile[]     @relation("UploadedFiles")
  taskComments     TaskComment[]  @relation("TaskComments")
  notifications    Notification[] @relation("UserNotifications")
}

model Client {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String
  businessType BusinessType
  source       ClientSource
  status       ClientStatus  @default(LEAD)
  stage        PipelineStage @default(NEW_LEAD)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  contactAttempts     Int       @default(0)
  lastContactAttemptAt DateTime?
  nextFollowUpAt      DateTime?
  followUpStep        Int       @default(0)

  assignedToId     String
  assignedTo       User           @relation("AssignedTo", fields: [assignedToId], references: [id])

  contracts        Contract[]
  proposals        Proposal[]
  projects         Project[]
  activities       ClientActivity[]

  requirements  Json?
  activityLog   Json?

  @@index([status])
  @@index([stage])
  @@index([assignedToId])
  @@index([nextFollowUpAt])
}

model Proposal {
  id                 String         @id @default(cuid())
  clientId           String
  client             Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  services           Json
  price              Float
  startDate          DateTime
  notes              String?
  status             ProposalStatus @default(DRAFT)
  shareToken         String?        @unique
  sentAt             DateTime?
  approvedAt         DateTime?
  revisionNotes      String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
}

model Contract {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  services    Json
  startDate   DateTime
  endDate     DateTime
  value       Float
  status      ContractStatus @default(DRAFT)
  fileUrl     String?
  sentAt      DateTime?
  signedAt    DateTime?
  signedByName String?
  signedByEmail String?
  signatureUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
}

model Project {
  id          String        @id @default(cuid())
  name        String
  description String?
  clientId    String
  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contractId  String?
  contract    Contract?     @relation(fields: [contractId], references: [id])
  managerId   String
  manager     User          @relation("ProjectManager", fields: [managerId], references: [id])
  status      ProjectStatus @default(PLANNING)
  progress    Float         @default(0)
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tasks       Task[]

  @@index([clientId])
  @@index([managerId])
  @@index([status])
}

model Task {
  id                   String         @id @default(cuid())
  title                String
  projectId            String
  project              Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo           String
  assignee             User           @relation("AssignedTask", fields: [assignedTo], references: [id])
  dept                 TaskDepartment
  status               TaskStatus     @default(TODO)
  dueDate              DateTime
  startDate            DateTime?
  priority             TaskPriority   @default(NORMAL)
  description          String?
  escalationLevel      Int            @default(0)
  escalationNotifiedAt DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  archivedAt           DateTime?

  files        TaskFile[]
  comments     TaskComment[]

  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([escalationLevel])
}

model ClientActivity {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  action    String
  details   String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([clientId])
}

enum NotificationType {
  // Existing values
  TASK_ASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMMENTED
  PROJECT_STATUS_CHANGED
  // New values
  TASK_UPDATED
  TASK_COMMENT_ADDED
  TASK_FILE_UPLOADED
  TASK_OVERDUE
  TASK_DELAY_WARNING
  TASK_ESCALATED_PM
  TASK_ESCALATED_ADMIN
  ADMIN_BROADCAST
  SYSTEM_ALERT
}

model TaskFile {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("UploadedFiles", fields: [uploadedById], references: [id])
  fileName     String
  filePath     String
  fileSize     Int
  mimeType     String
  createdAt    DateTime @default(now())

  @@index([taskId])
}

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("TaskComments", fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationType
  title      String
  message    String
  isRead     Boolean          @default(false)
  entityId   String?
  entityType String?
  createdAt  DateTime         @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@index([type])
}

model Invoice {
  id        String   @id @default(cuid())
  clientId  String
  amount    Float
  status    String   @default("PENDING")
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
