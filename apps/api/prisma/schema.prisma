// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PM
  SALES
  EMPLOYEE
  MARKETING
  ACCOUNTANT
  CLIENT
}

enum ClientStatus {
  LEAD
  ACTIVE
  PAUSED
  CLOSED
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          UserRole @default(EMPLOYEE)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  assignedClients Client[] @relation("AssignedTo")
  managedProjects Project[] @relation("ProjectManager")
  tasks           Task[]    @relation("AssignedTask")
}

model Client {
  id            String       @id @default(cuid())
  name          String
  phone         String
  email         String?
  businessName  String
  businessType  String
  source        String
  status        ClientStatus @default(LEAD)
  pipelineStage String       @default("NEW")
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  assignedTo    String
  assignedEmployee User      @relation("AssignedTo", fields: [assignedTo], references: [id])

  contracts     Contract[]
  projects      Project[]
  activities    ClientActivity[]
}

model Contract {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  services    Json
  startDate   DateTime
  endDate     DateTime
  value       Float
  status      String   @default("DRAFT")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects    Project[]
}

model Project {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id])
  managerId   String
  manager     User     @relation("ProjectManager", fields: [managerId], references: [id])
  status      String   @default("ONGOING")
  progress    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       Task[]
}

model Task {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  assignedTo  String
  assignee    User     @relation("AssignedTask", fields: [assignedTo], references: [id])
  dept        String
  status      String   @default("TODO")
  dueDate     DateTime
  priority    String   @default("NORMAL")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ClientActivity {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
}

model Invoice {
  id        String   @id @default(cuid())
  clientId  String
  amount    Float
  status    String   @default("PENDING")
  dueDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
