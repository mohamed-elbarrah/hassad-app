// apps/api/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum BusinessType {
  RESTAURANT
  CLINIC
  STORE
  SERVICE
  OTHER
}

enum ClientSource {
  AD
  REFERRAL
  WEBSITE
  WHATSAPP
  PLATFORM
}

enum PipelineStage {
  NEW
  INTRO_SENT
  CALL_ATTEMPT
  MEETING_SCHEDULED
  MEETING_DONE
  PROPOSAL_SENT
  FOLLOW_UP
  APPROVED
  CONTRACT_SIGNED
}

enum ClientStatus {
  LEAD
  ACTIVE
  STOPPED
}

enum ContactLogType {
  CALL
  WHATSAPP
  MEETING
  EMAIL
}

enum ContactLogResult {
  NO_RESPONSE
  RESPONDED
  BUSY
  WRONG_NUMBER
}

enum AutomationStatus {
  PENDING
  SUCCESS
  FAILED
}

enum ProposalStatus {
  DRAFT
  SENT
  APPROVED
  REVISION_REQUESTED
  REJECTED
}

enum ContractType {
  MONTHLY_RETAINER
  FIXED_PROJECT
  ONE_TIME_SERVICE
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  ACTIVE
  EXPIRED
  CANCELLED
}

enum RenewalAlertType {
  SIXTY_DAYS
  THIRTY_DAYS
  SEVEN_DAYS
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectMemberRole {
  MANAGER
  MEMBER
  VIEWER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  REVISION
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskDepartment {
  DESIGN
  CONTENT
  DEVELOPMENT
  MARKETING
  PRODUCTION
}

enum FilePurpose {
  DELIVERABLE
  REFERENCE
  INTERNAL_DRAFT
}

enum DelayAlertLevel {
  LOW
  MEDIUM
  HIGH
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  PAUSED
  STOPPED
  COMPLETED
}

enum CampaignPlatform {
  GOOGLE
  META
  TIKTOK
  SNAPCHAT
}




enum InvoiceStatus {
  DUE
  SENT
  PAID
  PARTIAL
  PENDING
  LATE
  CANCELLED
}

enum SalaryStatus {
  PENDING
  PAID
  CANCELLED
}

enum PaymentMethod {
  APPLE_PAY
  MADA
  VISA_MC
  TABBY
  TAMARA
  BANK_TRANSFER
  CARD
  CASH
}

enum TicketStatus {
  PENDING
  COLLECTION
  PAID
  LATE
}

enum TriggerEvent {
  PROJECT_COMPLETED
  TASK_APPROVED
  MONTHLY_REVIEW
}

enum AutoAction {
  NONE
  NOTIFY_PM
  ESC_TO_ADMIN
}

enum WorkloadStatus {
  AVAILABLE
  BUSY
  OVERLOADED
}

enum PaymentGatewayType {
  ONLINE
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentEventType {
  CREATED
  SUCCESS
  FAILED
  REFUNDED
}

enum AiEntityType {
  LEAD
  CLIENT
  PROJECT
  TASK

}

enum AiAnalysisType {
  CHURN_PREDICTION
  SENTIMENT_ANALYSIS
  PERFORMANCE_FORECAST
  CONTENT_GENERATION
  QUALITY_CHECK
}

enum AiSuggestionType {
  STRATEGY
  OPTIMIZATION
  CONTENT
}

enum AiSuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

// ─── Models ───────────────────────────────────────────────────────────────────

// 🟣 CORE & PERMISSIONS

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  roleId       String    @map("role_id")
  role         Role      @relation(fields: [roleId], references: [id], onUpdate: Cascade, onDelete: Restrict)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  permissions      UserPermission[]
  departments      UserDepartment[]
  assignedLeads    Lead[]                   @relation("LeadAssignee")
  createdLeads     Lead[]                   @relation("LeadCreator")
  leadHistory      LeadPipelineHistory[]
  contactLogs      LeadContactLog[]
  managedClients   Client[]                 @relation("AccountManager")
  clientHistory    ClientHistoryLog[]
  createdProposals Proposal[]
  createdContracts Contract[]               @relation("ContractCreator")
  contractVersions ContractVersion[]
  managedProjects  Project[]                @relation("ProjectManager")
  projectMembers   ProjectMember[]
  assignedTasks    Task[]                   @relation("TaskAssignee")
  createdTasks     Task[]                   @relation("TaskCreator")
  approvedTasks    Task[]                   @relation("TaskApprover")
  taskHistory      TaskStatusHistory[]
  uploadedFiles    TaskFile[]
  taskComments     TaskComment[]
  notifiedDelays   TaskDelayAlert[]
  approvedDelivs   Deliverable[]

  createdInvoices  Invoice[]
  assignedTickets  PaymentTicket[]          @relation("TicketAssignee")
  internalRatings  InternalRating[]         @relation("RatedBy")
  workload         StaffWorkload?
  chatParticipants ConversationParticipant[]
  sentMessages     Message[]
  triggeredAiLogs  AiAnalysisLog[]
  actionedAiSuggs  AiSuggestion[]
  notifications    Notification[]
  managedCampaigns Campaign[]               @relation("CampaignManager")
  kpiAuditLogs     CampaignKpiAuditLog[]   @relation("KpiAuditChanger")
  employee         Employee?

  ledgerEntries    Ledger[]



  @@map("users")
  @@index([roleId])
  @@index([createdAt])
}

model Role {
  id   String @id @default(uuid())
  name String @unique

  permissions RolePermission[]
  users       User[]

  @@map("roles")
}

model Permission {
  id   String @id @default(uuid())
  name String @unique

  roles RolePermission[]
  users UserPermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  userId       String @map("user_id")
  permissionId String @map("permission_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  userDepartments UserDepartment[]
  tasks           Task[]

  @@map("departments")
}

model UserDepartment {
  id           String @id @default(uuid())
  userId       String @map("user_id")
  departmentId String @map("department_id")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@map("user_departments")
  @@unique([userId, departmentId])
  @@index([userId])
  @@index([departmentId])
}


// 🔵 CRM & PIPELINE

model Lead {
  id                  String        @id @default(uuid())
  companyName         String        @map("company_name")
  contactName         String        @map("contact_name")
  phoneWhatsapp       String        @map("phone_whatsapp")
  email               String?
  businessName        String        @map("business_name")
  businessType        BusinessType  @map("business_type")
  source              ClientSource
  assignedTo          String?       @map("assigned_to")
  createdBy           String?       @map("created_by")
  pipelineStage       PipelineStage @map("pipeline_stage")
  contactAttemptCount Int           @default(0) @map("contact_attempt_count")
  lastContactAt       DateTime?     @map("last_contact_at")
  notes               String?
  isActive            Boolean       @default(true) @map("is_active")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  assignee        User?                  @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator         User?                  @relation("LeadCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  pipelineHistory LeadPipelineHistory[]
  contactLogs     LeadContactLog[]
  automationLogs  LeadAutomationLog[]
  client          Client?
  proposals       Proposal[]

  @@map("leads")
  @@index([assignedTo])
  @@index([createdBy])
  @@index([pipelineStage])
  @@index([createdAt])
}

model LeadPipelineHistory {
  id        String        @id @default(uuid())
  leadId    String        @map("lead_id")
  fromStage PipelineStage @map("from_stage")
  toStage   PipelineStage @map("to_stage")
  changedBy String        @map("changed_by")
  changedAt DateTime      @default(now()) @map("changed_at")

  lead    Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  changer User @relation(fields: [changedBy], references: [id], onDelete: Restrict)

  @@map("lead_pipeline_history")
  @@index([leadId])
  @@index([changedAt])
}

model LeadContactLog {
  id          String           @id @default(uuid())
  leadId      String           @map("lead_id")
  userId      String           @map("user_id")
  type        ContactLogType
  result      ContactLogResult
  notes       String?
  contactedAt DateTime         @default(now()) @map("contacted_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("lead_contact_log")
  @@index([leadId])
  @@index([userId])
}

model LeadAutomationRule {
  id            String   @id @default(uuid())
  name          String
  triggerType   String   @map("trigger_type")
  conditionJson Json     @map("condition_json")
  actionJson    Json     @map("action_json")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  logs LeadAutomationLog[]

  @@map("lead_automation_rules")
}

model LeadAutomationLog {
  id           String           @id @default(uuid())
  leadId       String           @map("lead_id")
  ruleId       String           @map("rule_id")
  executedAt   DateTime         @default(now()) @map("executed_at")
  status       AutomationStatus
  responseData Json?            @map("response_data")

  lead Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  rule LeadAutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@map("lead_automation_logs")
  @@index([leadId])
  @@index([ruleId])
}

model Client {
  id                   String       @id @default(uuid())
  leadId               String?      @unique @map("lead_id")
  companyName          String       @map("company_name")
  contactName          String       @map("contact_name")
  phoneWhatsapp        String       @map("phone_whatsapp")
  email                String?
  businessName         String       @map("business_name")
  businessType         BusinessType @map("business_type")
  accountManager       String?      @map("account_manager")
  status               ClientStatus
  portalAccessToken    String?      @unique @map("portal_access_token")
  portalTokenExpiresAt DateTime?    @map("portal_token_expires_at")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  lead         Lead?                @relation(fields: [leadId], references: [id], onDelete: SetNull)
  manager      User?                @relation("AccountManager", fields: [accountManager], references: [id], onDelete: SetNull)
  historyLogs  ClientHistoryLog[]
  contracts    Contract[]
  projects     Project[]
  revisionReqs ClientRevisionRequest[]
  intakeForms  PortalIntakeForm[]

  invoices     Invoice[]
  payTickets   PaymentTicket[]
  payments     Payment[]
  satRatings   SatisfactionRating[]
  campaigns    Campaign[]


  @@map("clients")
  @@index([accountManager])
  @@index([status])
  @@index([createdAt])
}

model ClientHistoryLog {
  id          String   @id @default(uuid())
  clientId    String   @map("client_id")
  userId      String   @map("user_id")
  eventType   String   @map("event_type") // ENUM in .md but values vary
  description String
  metadata    Json?
  occurredAt  DateTime @default(now()) @map("occurred_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("client_history_log")
  @@index([clientId])
  @@index([occurredAt])
}

// 🟠 PROPOSALS & CONTRACTS

model Proposal {
  id                 String         @id @default(uuid())
  leadId             String?        @map("lead_id")
  createdBy          String         @map("created_by")
  title              String
  serviceDescription String         @map("service_description")
  servicesList       Json           @map("services_list")
  totalPrice         Float          @map("total_price")
  durationDays       Int            @map("duration_days")
  platforms          Json
  filePath           String?        @map("file_path")
  status             ProposalStatus
  shareLinkToken     String?        @unique @map("share_link_token")
  sentAt             DateTime?      @map("sent_at")
  approvedAt         DateTime?      @map("approved_at")
  createdAt          DateTime       @default(now()) @map("created_at")

  lead     Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)
  creator  User       @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  contract Contract?

  @@map("proposals")
  @@index([leadId])
  @@index([createdBy])
  @@index([status])
}

model Contract {
  id           String         @id @default(uuid())
  clientId     String         @map("client_id")
  proposalId   String?        @unique @map("proposal_id")
  createdBy    String         @map("created_by")
  title        String
  type         ContractType
  status       ContractStatus
  startDate    DateTime       @map("start_date")
  endDate      DateTime       @map("end_date")
  monthlyValue Float          @map("monthly_value")
  totalValue   Float          @map("total_value")
  currency     String         @default("SAR") @map("currency")
  filePath        String?        @map("file_path")
  shareLinkToken  String?        @unique @map("share_link_token")
  versionNumber   Int            @default(1) @map("version_number")
  eSigned         Boolean        @default(false) @map("e_signed")
  signedAt        DateTime?      @map("signed_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  client       Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  proposal     Proposal?               @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  creator      User                    @relation("ContractCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  versions     ContractVersion[]
  renewalAlerts ContractRenewalAlert[]
  projects     Project[]
  invoices     Invoice[]

  @@map("contracts")
  @@index([clientId])
  @@index([status])
}

model ContractVersion {
  id            String   @id @default(uuid())
  contractId    String   @map("contract_id")
  versionNumber Int      @map("version_number")
  filePath      String   @map("file_path")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  creator  User     @relation(fields: [createdBy], references: [id], onDelete: Restrict)

  @@map("contract_versions")
  @@index([contractId])
}

model ContractRenewalAlert {
  id         String           @id @default(uuid())
  contractId String           @map("contract_id")
  alertType  RenewalAlertType @map("alert_type")
  isSent     Boolean          @default(false) @map("is_sent")
  scheduledAt DateTime         @map("scheduled_at")
  sentAt     DateTime?        @map("sent_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("contract_renewal_alerts")
  @@index([contractId])
}

// 🟢 PROJECT MANAGEMENT

model Project {
  id                 String        @id @default(uuid())
  clientId           String        @map("client_id")
  contractId         String?       @map("contract_id")
  projectManagerId   String?       @map("project_manager_id")
  name               String
  description        String?
  status             ProjectStatus
  priority           TaskPriority  @map("priority")
  startDate          DateTime      @map("start_date")
  endDate            DateTime      @map("end_date")
  completionPercentage Float       @default(0) @map("completion_percentage")
  isArchived         Boolean       @default(false) @map("is_archived")
  archivedAt         DateTime?     @map("archived_at")
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  client         Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract       Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  manager        User?                @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: SetNull)
  members        ProjectMember[]
  tasks          Task[]
  deliverables   Deliverable[]
  campaigns      Campaign[]
  invoiceItems   InvoiceItem[]


  satRatings     SatisfactionRating[]

  @@map("projects")
  @@index([clientId])
  @@index([projectManagerId])
  @@index([status])
}

model ProjectMember {
  id        String            @id @default(uuid())
  projectId String            @map("project_id")
  userId    String            @map("user_id")
  role      ProjectMemberRole
  joinedAt  DateTime          @default(now()) @map("joined_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("project_members")
  @@index([projectId])
  @@index([userId])
}

model Task {
  id                String         @id @default(uuid())
  projectId         String         @map("project_id")
  departmentId      String         @map("department_id")
  assignedTo        String?        @map("assigned_to")
  createdBy         String         @map("created_by")
  approvedBy        String?        @map("approved_by")
  title             String
  description       String?
  status            TaskStatus
  priority          TaskPriority
  dueDate           DateTime       @map("due_date")
  startedAt         DateTime?      @map("started_at")
  submittedAt       DateTime?      @map("submitted_at")
  approvedAt        DateTime?      @map("approved_at")
  revisionCount     Int            @default(0) @map("revision_count")
  isVisibleToClient Boolean        @default(false) @map("is_visible_to_client")
  archivedAt        DateTime?      @map("archived_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  department     Department          @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  assignee       User?               @relation("TaskAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  creator        User                @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  approver       User?               @relation("TaskApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  statusHistory  TaskStatusHistory[]
  files          TaskFile[]
  comments       TaskComment[]
   delayAlerts    TaskDelayAlert[]
   deliverables Deliverable[]
   invoiceItems  InvoiceItem[]
   internalRating InternalRating?
   campaigns    Campaign[]



  @@map("tasks")
  @@index([projectId])
  @@index([assignedTo])
  @@index([status])
  @@index([createdAt])
}

model TaskStatusHistory {
  id         String     @id @default(uuid())
  taskId     String     @map("task_id")
  fromStatus TaskStatus @map("from_status")
  toStatus   TaskStatus @map("to_status")
  changedBy  String     @map("changed_by")
  changedAt  DateTime   @default(now()) @map("changed_at")

  task    Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changer User @relation(fields: [changedBy], references: [id], onDelete: Restrict)

  @@map("task_status_history")
  @@index([taskId])
}

model TaskFile {
  id         String      @id @default(uuid())
  taskId     String      @map("task_id")
  uploadedBy String      @map("uploaded_by")
  filePath   String      @map("file_path")
  fileName   String      @map("file_name")
  fileType   String      @map("file_type")
  fileSize   Int         @map("file_size")
  purpose    FilePurpose
  uploadedAt DateTime    @default(now()) @map("uploaded_at")

  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader User @relation(fields: [uploadedBy], references: [id], onDelete: Restrict)

  @@map("task_files")
  @@index([taskId])
}

model TaskComment {
  id              String   @id @default(uuid())
  taskId          String   @map("task_id")
  userId          String   @map("user_id")
  content         String
  isInternal      Boolean  @default(true) @map("is_internal")
  createdAt       DateTime @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@map("task_comments")
  @@index([taskId])
}

model TaskDelayAlert {
  id             String          @id @default(uuid())
  taskId         String          @map("task_id")
  notifiedUserId String          @map("notified_user_id")
  alertLevel     DelayAlertLevel @map("alert_level")
  isAcknowledged Boolean         @default(false) @map("is_acknowledged")
  triggeredAt    DateTime        @default(now()) @map("triggered_at")
  acknowledgedAt DateTime?       @map("acknowledged_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [notifiedUserId], references: [id], onDelete: Restrict)

  @@map("task_delay_alerts")
  @@index([taskId])
}

model Campaign {
  id                  String           @id @default(uuid())
  clientId            String           @map("client_id")
  taskId              String           @map("task_id")
  projectId           String?          @map("project_id")
  managedBy           String           @map("managed_by")
  name                String
  platform            CampaignPlatform
  status              CampaignStatus   @default(PLANNING)
  startDate           DateTime         @map("start_date")
  endDate             DateTime?        @map("end_date")
  budgetTotal         Float            @default(0) @map("budget_total")
  budgetSpent         Float            @default(0) @map("budget_spent")
  currency            String           @default("SAR") @map("currency")
  needsOptimization   Boolean          @default(false) @map("needs_optimization")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  client             Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  task               Task                    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project            Project?                @relation(fields: [projectId], references: [id], onDelete: SetNull)
  manager            User                    @relation("CampaignManager", fields: [managedBy], references: [id])
  kpiSnapshots       CampaignKpiSnapshot[]
  auditLogs          CampaignKpiAuditLog[]
  platformConnections AdPlatformConnection[]

  @@map("campaigns")
  @@index([taskId])
  @@index([clientId])
}

model CampaignKpiSnapshot {
  id           String   @id @default(uuid())
  campaignId   String   @map("campaign_id")
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  conversions  Int      @default(0)
  revenue      Float    @default(0)
  cpc          Float    @default(0) // cost per click
  cpa          Float    @default(0) // cost per acquisition
  ctr          Float    @default(0) // click-through rate (%)
  conversionRate Float  @default(0) // conversion rate (%)
  roas         Float    @default(0) // return on ad spend
  source       String? // e.g. "manual", "meta_api", "google_api"
  recordedAt   DateTime @default(now()) @map("recorded_at")
  createdAt    DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  auditLogs CampaignKpiAuditLog[]

  @@map("campaign_kpi_snapshots")
  @@index([campaignId])
  @@index([recordedAt])
}

model CampaignKpiAuditLog {
  id            String   @id @default(uuid())
  campaignId    String   @map("campaign_id")
  snapshotId    String?  @map("snapshot_id")
  field         String
  oldValue      String?
  newValue      String?
  changedBy     String?  @map("changed_by")
  createdAt     DateTime @default(now()) @map("created_at")

  campaign Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  snapshot CampaignKpiSnapshot?  @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  changer  User?                @relation("KpiAuditChanger", fields: [changedBy], references: [id], onDelete: SetNull)

  @@map("campaign_kpi_audit_logs")
  @@index([campaignId])
}

model AdPlatformConnection {
  id                  String            @id @default(uuid())
  campaignId          String            @map("campaign_id")
  platform            CampaignPlatform
  externalCampaignId  String?           @map("external_campaign_id")
  accessToken         String?           @map("access_token")
  refreshToken        String?           @map("refresh_token")
  syncStatus          String            @default("PENDING") @map("sync_status")
  lastSyncedAt        DateTime?         @map("last_synced_at")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("ad_platform_connections")
  @@index([campaignId])
}


// 🟦 CLIENT PORTAL

model Deliverable {
  id                String            @id @default(uuid())
  projectId         String            @map("project_id")
  taskId            String?           @map("task_id")
  approvedBy        String?           @map("approved_by")
  title             String
  description       String?
  filePath          String            @map("file_path")
  status            TaskStatus        @default(TODO) // Reuses TaskStatus or needs its own DeliverableStatus
  isVisibleToClient Boolean           @default(true) @map("is_visible_to_client")
  approvedAt        DateTime?         @map("approved_at")
  createdAt         DateTime          @default(now()) @map("created_at")

  project          Project                  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task             Task?                    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  approver         User?                    @relation(fields: [approvedBy], references: [id], onDelete: SetNull)
  revisionRequests ClientRevisionRequest[]

  @@map("deliverables")
  @@index([projectId])
}

model ClientRevisionRequest {
  id                 String     @id @default(uuid())
  deliverableId      String     @map("deliverable_id")
  clientId           String     @map("client_id")
  requestDescription String     @map("request_description")
  status             TaskStatus @default(TODO)
  createdAt          DateTime   @default(now()) @map("created_at")
  resolvedAt         DateTime?  @map("resolved_at")

  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("client_revision_requests")
  @@index([deliverableId])
  @@index([clientId])
}

model PortalIntakeForm {
  id                  String    @id @default(uuid())
  clientId            String    @map("client_id")
  token               String    @unique
  businessDescription String?   @map("business_description")
  goals               Json?
  uploadedFiles       Json?     @map("uploaded_files")
  isSubmitted         Boolean   @default(false) @map("is_submitted")
  submittedAt         DateTime? @map("submitted_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("portal_intake_forms")
  @@index([clientId])
}


// 🟡 FINANCE

model Invoice {
  id               String        @id @default(uuid())
  clientId         String        @map("client_id")
  contractId       String?       @map("contract_id")
  createdBy        String        @map("created_by")
  invoiceNumber    String        @unique @map("invoice_number")
  amount           Float
  currency         String           @default("SAR") @map("currency")
  status           InvoiceStatus
  paymentMethod    PaymentMethod @map("payment_method")
  issueDate        DateTime      @map("issue_date")
  dueDate          DateTime      @map("due_date")
  paidAt           DateTime?     @map("paid_at")
  sentAt           DateTime?     @map("sent_at")
  paymentReference String?       @map("payment_reference")
  notes            String?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  client   Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  contract Contract?       @relation(fields: [contractId], references: [id], onDelete: SetNull)
  creator  User            @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  tickets  PaymentTicket[]
  payments Payment[]
  items    InvoiceItem[]

  @@map("invoices")
  @@index([clientId])
  @@index([invoiceNumber])
  @@index([status])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String  @map("invoice_id")
  projectId   String? @map("project_id")
  taskId      String? @map("task_id")
  description String
  quantity     Int     @default(1)
  unitPrice   Float   @map("unit_price")
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("invoice_items")
  @@index([invoiceId])
  @@index([projectId])
  @@index([taskId])
}

model Payment {
  id                 String           @id @default(uuid())
  invoiceId          String           @map("invoice_id")
  clientId           String?          @map("client_id")
  gatewayId          String?          @map("gateway_id")
  amount             Float
  currency           String           @default("SAR")
  status             PaymentStatus
  method             PaymentMethod
  providerPaymentId  String?          @map("provider_payment_id")
  metadataJson       Json?            @map("metadata_json")
  notes              String?
  date               DateTime         @default(now())
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  invoice   Invoice         @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client    Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  gateway   PaymentGateway? @relation(fields: [gatewayId], references: [id], onDelete: SetNull)
  events    PaymentEvent[]

  @@map("payments")
  @@index([invoiceId])
  @@index([clientId])
  @@index([gatewayId])
  @@index([status])
  @@index([providerPaymentId])
}

model PaymentGateway {
  id          String             @id @default(uuid())
  name        String             @unique // stripe, bank_transfer
  type        PaymentGatewayType
  isActive    Boolean            @default(true) @map("is_active")
  configJson  Json?              @map("config_json") // Encrypted keys
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  payments    Payment[]

  @@map("payment_gateways")
}

model BankAccount {
  id           String   @id @default(uuid())
  accountName  String   @map("account_name")
  iban         String   @unique
  bankName     String   @map("bank_name")
  swiftCode    String?  @map("swift_code")
  instructions String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("bank_accounts")
}

model PaymentEvent {
  id          String           @id @default(uuid())
  paymentId   String           @map("payment_id")
  type        PaymentEventType
  payloadJson Json?            @map("payload_json")
  createdAt   DateTime         @default(now()) @map("created_at")

  payment     Payment          @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@map("payment_events")
}

model WebhookLog {
  id          String   @id @default(uuid())
  provider    String
  eventType   String   @map("event_type")
  payload     Json
  processed   Boolean  @default(false)
  error       String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("webhook_logs")
}

model Employee {
  id         String   @id @default(uuid())
  userId     String?  @unique @map("user_id")
  name       String
  role       String
  baseSalary Float    @map("base_salary")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user     User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  salaries Salary[]

  @@map("employees")
}

model Salary {
  id          String       @id @default(uuid())
  employeeId  String       @map("employee_id")
  amount      Float
  baseSalary  Float        @map("base_salary")
  bonuses     Float        @default(0)
  deductions  Float        @default(0)
  status      SalaryStatus
  paymentDate DateTime?    @map("payment_date")
  month       Int
  year        Int
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@map("salaries")
  @@index([employeeId])
  @@index([status])
}

model Ledger {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String   @map("entity_id")
  userId    String?  @map("user_id")
  before    Json?
  after     Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ledger")
  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model PaymentTicket {
  id         String       @id @default(uuid())
  invoiceId  String       @map("invoice_id")
  clientId   String       @map("client_id")
  assignedTo String?      @map("assigned_to")
  status     TicketStatus
  notes      String?
  createdAt  DateTime     @default(now()) @map("created_at")
  resolvedAt DateTime?    @map("resolved_at")

  invoice  Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TicketAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)

  @@map("payment_tickets")
  @@index([invoiceId])
  @@index([clientId])
}

// 🟣 RATINGS & PERFORMANCE

model SatisfactionRating {
  id           String       @id @default(uuid())
  clientId     String       @map("client_id")
  projectId    String?      @map("project_id")
  score        Int
  comment      String?
  triggerEvent TriggerEvent @map("trigger_event")
  autoAction   AutoAction   @map("auto_action")
  createdAt    DateTime     @default(now()) @map("created_at")

  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@map("satisfaction_ratings")
  @@index([clientId])
}

model InternalRating {
  id        String   @id @default(uuid())
  taskId    String   @unique @map("task_id")
  ratedBy   String   @map("rated_by")
  score     Int
  feedback  String?
  createdAt DateTime @default(now()) @map("created_at")

  task  Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  rater User @relation("RatedBy", fields: [ratedBy], references: [id], onDelete: Restrict)

  @@map("internal_ratings")
  @@index([taskId])
}

model StaffWorkload {
  id                    String         @id @default(uuid())
  userId                String         @unique @map("user_id")
  activeTasksCount      Int            @default(0) @map("active_tasks_count")
  workloadStatus        WorkloadStatus @map("workload_status")
  avgCompletionSpeedDays Float          @default(0) @map("avg_completion_speed_days")
  avgQualityScore       Float          @default(0) @map("avg_quality_score")
  calculatedAt          DateTime       @default(now()) @map("calculated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("staff_workload")
}

// ⚫ COMMUNICATION (CHAT)

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")
  userId         String @map("user_id")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("conversation_participants")
  @@index([conversationId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  senderId       String   @map("sender_id")
  content        String
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                @relation(fields: [senderId], references: [id], onDelete: Restrict)
  attachments  MessageAttachment[]

  @@map("messages")
  @@index([conversationId])
  @@index([createdAt])
}

model MessageAttachment {
  id         String   @id @default(uuid())
  messageId  String   @map("message_id")
  filePath   String   @map("file_path")
  fileName   String   @map("file_name")
  fileType   String   @map("file_type")
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("message_attachments")
  @@index([messageId])
}

// ⚪ NOTIFICATIONS

model NotificationEvent {
  id          String   @id @default(uuid())
  entityId    String   @map("entity_id")
  entityType  String   @map("entity_type")
  eventType   String   @map("event_type")
  metadata    Json?
  triggeredAt DateTime @default(now()) @map("triggered_at")

  notifications Notification[]

  @@map("notification_events")
}

model Notification {
  id      String    @id @default(uuid())
  eventId String    @map("event_id")
  userId  String    @map("user_id")
  title   String
  body    String
  isRead  Boolean   @default(false) @map("is_read")
  channel String // email, push, etc.
  sentAt  DateTime? @map("sent_at")
  readAt  DateTime? @map("read_at")

  event NotificationEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
  @@index([userId])
  @@index([isRead])
  @@index([sentAt])
}

// 🔵 AI LAYER

model AiAnalysisLog {
  id              String         @id @default(uuid())
  entityId        String         @map("entity_id")
  entityType      AiEntityType   @map("entity_type")
  analysisType    AiAnalysisType @map("analysis_type")
  inputData       Json           @map("input_data")
  outputData      Json           @map("output_data")
  confidenceScore Float          @map("confidence_score")
  triggeredBy     String?        @map("triggered_by")
  createdAt       DateTime       @default(now()) @map("created_at")

  user        User?          @relation(fields: [triggeredBy], references: [id], onDelete: SetNull)
  suggestions AiSuggestion[]

  @@map("ai_analysis_logs")
  @@index([entityId])
  @@index([analysisType])
}

model AiSuggestion {
  id             String             @id @default(uuid())
  logId          String             @map("log_id")
  entityId       String             @map("entity_id")
  suggestionType AiSuggestionType   @map("suggestion_type")
  description    String
  status         AiSuggestionStatus
  actionedBy     String?            @map("actioned_by")
  createdAt      DateTime           @default(now()) @map("created_at")
  actionedAt     DateTime?          @map("actioned_at")

  log    AiAnalysisLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  actor  User?         @relation(fields: [actionedBy], references: [id], onDelete: SetNull)

  @@map("ai_suggestions")
  @@index([logId])
  @@index([status])
}

model CurrencySetting {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  symbol    String
  isDefault Boolean @default(false) @map("is_default")
  exchangeRate Float @default(1) @map("exchange_rate")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("currency_settings")
}
