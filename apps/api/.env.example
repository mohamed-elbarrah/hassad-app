# apps/api/.env.example

# Database Configuration
# Using Docker: postgresql://hassad:hassad_dev_password@localhost:5432/hassad
DATABASE_URL="postgresql://user:password@localhost:5432/database"

# Authentication Secrets
JWT_SECRET="your_long_random_secret_here"
JWT_REFRESH_SECRET="your_another_long_random_secret_here"

# Auth Expiration Settings
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
COOKIE_TOKEN_MAX_AGE=3600000
COOKIE_REFRESH_TOKEN_MAX_AGE=604800000

# File Storage (Cloudflare R2)
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""

# Payments (Moyasar)
MOYASAR_API_KEY=""

# API Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for email links, CORS, OAuth callbacks)
FRONTEND_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# Email (SMTP) — Test credentials from https://ethereal.email
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Hassad Platform <noreply@hassad.sa>"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/google/callback

# Snapchat OAuth
SNAPCHAT_CLIENT_ID=""
SNAPCHAT_CLIENT_SECRET=""
SNAPCHAT_CALLBACK_URL=http://localhost:3001/v1/auth/snapchat/callback
